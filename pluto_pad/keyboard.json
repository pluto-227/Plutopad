{
    "keyboard_name": "Pluto Pad",
    "url": "https://github.com/pluto-227/Plutopad",
    "maintainer": "pluto-227",
    "manufacturer": "pluto-227",
    "width": 5,
    "height": 3,
    "bootloader": "rp2040",
    "diode_direction": "COL2ROW",
    "processor": "RP2040",
    "usb": {
        "device_version": "1.0.0",
        "pid": "0x0001",
        "vid": "0xFEED"
    },
    "matrix_size": {
        "rows": 3,
        "cols": 5
    },
    "matrix_pins": {
        "cols": ["GP3", "GP6", "GP7", "GP2", "GP10"],
        "rows": ["GP0", "GP1", "GP2"]
    },

    "encoder": {
        "rotary": [
            {
                "pin_a": "GP8",
                "pin_b": "GP9",
                "resolution": 4
            }
        ]
    },


    "layouts": {
        "LAYOUT_3x5": {
            "layout": [
                {"matrix": [0, 0], "x": 0, "y": 0},
                {"matrix": [0, 4], "x": 4, "y": 0},
                {"matrix": [1, 1], "x": 1, "y": 1},
                {"matrix": [1, 2], "x": 2, "y": 1},
                {"matrix": [1, 3], "x": 3, "y": 1},
                {"matrix": [2, 0], "x": 0, "y": 2},
                {"matrix": [2, 1], "x": 1, "y": 2},
                {"matrix": [2, 2], "x": 2, "y": 2},
                {"matrix": [2, 3], "x": 3, "y": 2},
                {"matrix": [2, 4], "x": 4, "y": 2}

            ]
        }
    }
}

